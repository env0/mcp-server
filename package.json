{
  "name": "@env0/mcp-server",
  "version": "1.0.0",
  "type": "module",
  "main": "index.ts",
  "scripts": {
    "build": "tsc",
    "start": "tsx src/cli.ts",
    "dev": "tsx watch src/cli.ts",
    "test": "npm test",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit"
  },
  "author": "Env0",
  "license": "Apache-2.0",
  "description": "Env0's official MCP server",
  "ts-node": {
    "esm": true,
    "experimentalSpecifierResolution": "node"
  },
  "devDependencies": {
    "@types/axios": "^0.14.4",
    "@types/express": "5.0.3",
    "@types/node": "24.2.1",
    "@typescript-eslint/eslint-plugin": "8.39.1",
    "@typescript-eslint/parser": "8.39.1",
    "eslint": "9.33.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.4",
    "eslint-plugin-unused-imports": "4.1.4",
    "nodemon": "3.1.10",
    "prettier": "3.6.2",
    "ts-node": "10.9.2",
    "typescript": "5.9.2",
    "@types/lodash": "4.17.20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.17.2",
    "axios": "^1.13.5",
    "dotenv": "17.2.1",
    "express": "5.1.0",
    "morgan": "1.10.1",
    "zod": "3.25.76",
    "lodash": "4.17.21",
    "tsx": "4.20.4"
  }
}
